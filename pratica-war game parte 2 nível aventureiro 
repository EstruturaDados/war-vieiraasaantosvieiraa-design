#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

// --- Definicao da estrutura (struct) ---
struct Territorio {
    char nome[30];
    char cor[10];
    int tropas;
};

// =================================================== //
// Funcao para cadastrar os territorios
// =================================================== //
void cadastrarTerritorios(struct Territorio *territorios, int quantidade) {

    int i;

    for(i = 0; i < quantidade; i++) {

        printf("=====================================\n");
        printf("Cadastro do Territorio %d\n", i + 1);
        printf("=====================================\n");

        // Nome do territorio
        printf("Digite o nome do territorio: ");
        fgets((territorios + i)->nome, 30, stdin);

        // Remove o \n do fgets
        (territorios + i)->nome[
            strcspn((territorios + i)->nome, "\n")
        ] = '\0';

        // Cor do exercito
        printf("Digite a cor do exercito: ");
        fgets((territorios + i)->cor, 10, stdin);

        // Remove o \n do fgets
        (territorios + i)->cor[
            strcspn((territorios + i)->cor, "\n")
        ] = '\0';

        // Quantidade de tropas
        printf("Digite a quantidade de tropas: ");
        scanf("%d", &(territorios + i)->tropas);

        // Limpa buffer
        getchar();

        printf("\nTerritorio cadastrado com sucesso!\n\n");
    }
}

// =================================================== //
// Funcao para exibir os territorios
// =================================================== //
void exibirTerritorios(struct Territorio *territorios, int quantidade) {

    int i;

    printf("\n=====================================\n");
    printf("TERRITORIOS CADASTRADOS\n");
    printf("=====================================\n");

    for(i = 0; i < quantidade; i++) {

        printf("\nTerritorio %d\n", i + 1);
        printf("Nome: %s\n", (territorios + i)->nome);
        printf("Cor do exercito: %s\n", (territorios + i)->cor);
        printf("Quantidade de tropas: %d\n", (territorios + i)->tropas);

        printf("-------------------------------------\n");
    }
}

// =================================================== //
// Funcao de ataque
// =================================================== //
void atacar(struct Territorio *atacante,
             struct Territorio *defensor) {

    int dadoAtacante;
    int dadoDefensor;

    printf("\n=====================================\n");
    printf("BATALHA INICIADA\n");
    printf("=====================================\n");

    printf("Atacante: %s (%s)\n",
           atacante->nome,
           atacante->cor);

    printf("Defensor: %s (%s)\n",
           defensor->nome,
           defensor->cor);

    // Sorteio dos dados
    dadoAtacante = rand() % 6 + 1;
    dadoDefensor = rand() % 6 + 1;

    printf("\nDado do atacante: %d\n", dadoAtacante);
    printf("Dado do defensor: %d\n", dadoDefensor);

    // Verifica vencedor
    if(dadoAtacante > dadoDefensor) {

        printf("\nO atacante venceu a batalha!\n");

        // Troca a cor do territorio defensor
        strcpy(defensor->cor, atacante->cor);

        // Metade das tropas do atacante vai para o defensor
        defensor->tropas = atacante->tropas / 2;

        // Remove tropas do atacante
        atacante->tropas =
            atacante->tropas - defensor->tropas;

    } else {

        printf("\nO defensor venceu a batalha!\n");

        // Atacante perde 1 tropa
        atacante->tropas--;

        // Evita tropas negativas
        if(atacante->tropas < 0) {
            atacante->tropas = 0;
        }
    }

    printf("=====================================\n");
}

// =================================================== //
// Funcao para liberar memoria
// =================================================== //
void liberarMemoria(struct Territorio *territorios) {

    free(territorios);

    printf("\nMemoria liberada com sucesso!\n");
}

// =================================================== //
// Funcao principal
// =================================================== //
int main() {

    // Inicializa numeros aleatorios
    srand(time(NULL));

    struct Territorio *territorios;

    int quantidade;
    int atacanteIndice;
    int defensorIndice;

    // ===================================================
    // Quantidade de territorios
    // ===================================================
    printf("Quantos territorios deseja cadastrar? ");
    scanf("%d", &quantidade);

    getchar();

    // ===================================================
    // Alocacao dinamica com calloc
    // ===================================================
    territorios = (struct Territorio*)
        calloc(quantidade, sizeof(struct Territorio));

    // Verifica erro de memoria
    if(territorios == NULL) {

        printf("Erro ao alocar memoria!\n");

        return 1;
    }

    // ===================================================
    // Cadastro dos territorios
    // ===================================================
    cadastrarTerritorios(territorios, quantidade);

    // ===================================================
    // Exibicao inicial
    // ===================================================
    exibirTerritorios(territorios, quantidade);

    // ===================================================
    // Escolha do atacante
    // ===================================================
    printf("\n=====================================\n");
    printf("ESCOLHA O TERRITORIO ATACANTE\n");
    printf("=====================================\n");

    for(int i = 0; i < quantidade; i++) {

        printf("%d - %s (%s)\n",
               i,
               (territorios + i)->nome,
               (territorios + i)->cor);
    }

    printf("\nDigite o numero do atacante: ");
    scanf("%d", &atacanteIndice);

    // ===================================================
    // Escolha do defensor
    // ===================================================
    printf("\n=====================================\n");
    printf("ESCOLHA O TERRITORIO DEFENSOR\n");
    printf("=====================================\n");

    for(int i = 0; i < quantidade; i++) {

        // Nao mostra territorios da mesma cor
        if(strcmp(
            (territorios + i)->cor,
            (territorios + atacanteIndice)->cor
           ) != 0) {

            printf("%d - %s (%s)\n",
                   i,
                   (territorios + i)->nome,
                   (territorios + i)->cor);
        }
    }

    printf("\nDigite o numero do defensor: ");
    scanf("%d", &defensorIndice);

    // ===================================================
    // Validacao do ataque
    // ===================================================
    if(strcmp(
        (territorios + atacanteIndice)->cor,
        (territorios + defensorIndice)->cor
       ) == 0) {

        printf("\nErro! Nao e permitido atacar um territorio da mesma cor.\n");

    } else {

        // Realiza ataque
        atacar(
            territorios + atacanteIndice,
            territorios + defensorIndice
        );

        // ===================================================
        // Exibicao apos ataque
        // ===================================================
        printf("\n=====================================\n");
        printf("MAPA APOS A BATALHA\n");
        printf("=====================================\n");

        exibirTerritorios(territorios, quantidade);
    }

    // ===================================================
    // Libera memoria
    // ===================================================
    liberarMemoria(territorios);

    return 0;
}