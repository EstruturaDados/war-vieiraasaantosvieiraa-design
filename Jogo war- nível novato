// objetivo desta parte:
// implementar o cadastro de nome, cor e tropas.
// foco em STRUCTS, entrada, saida de dados e organizacao basica.
// =================================================== //

#include <stdio.h>
#include <string.h>

// --- Constantes Globais ---
#define MAX_TERRITORIOS 5

// --- Definicao da estrutura (struct) ---
// A struct Territorio armazena:
// nome do territorio,
// cor do exercito,
// quantidade de tropas.
struct Territorio {
    char nome[30];
    char cor[10];
    int tropas;
};

// --- Funcao principal ---
int main() {

    // Vetor de structs para armazenar 5 territorios
    struct Territorio territorios[MAX_TERRITORIOS];

    // Variavel de controle do laco
    int i;

    // ===================================================
    // Cadastro dos territorios
    // ===================================================
    for(i = 0; i < MAX_TERRITORIOS; i++) {

        printf("=====================================\n");
        printf("Cadastro do Territorio %d\n", i + 1);
        printf("=====================================\n");

        // Entrada do nome
        printf("Digite o nome do territorio: ");
        fgets(territorios[i].nome, 30, stdin);

        // Remove o '\n' do fgets
        territorios[i].nome[
            strcspn(territorios[i].nome, "\n")
        ] = '\0';

        // Entrada da cor
        printf("Digite a cor do exercito: ");
        fgets(territorios[i].cor, 10, stdin);

        // Remove o '\n' do fgets
        territorios[i].cor[
            strcspn(territorios[i].cor, "\n")
        ] = '\0';

        // Entrada das tropas
        printf("Digite a quantidade de tropas: ");
        scanf("%d", &territorios[i].tropas);

        // Limpa o buffer do teclado
        getchar();

        printf("\nTerritorio cadastrado com sucesso!\n\n");
    }

    // ===================================================
    // Exibicao dos territorios cadastrados
    // ===================================================
    printf("\n=====================================\n");
    printf("TERRITORIOS CADASTRADOS\n");
    printf("=====================================\n");

    for(i = 0; i < MAX_TERRITORIOS; i++) {

        printf("\nTerritorio %d\n", i + 1);
        printf("Nome: %s\n", territorios[i].nome);
        printf("Cor do exercito: %s\n", territorios[i].cor);
        printf("Quantidade de tropas: %d\n", territorios[i].tropas);

        printf("-------------------------------------\n");
    }

    return 0;
}
